# ============================================================================
# PATIENT DATA — NEVER COMMIT. Infant video is identifiable health data.
# ============================================================================
runs/
webapp/data_runtime/
*.mp4
*.MP4
*.mov
*.avi
*.mkv
models/*.joblib
models/*.csv
models/*.zip
# pose keypoints are still identifiable movement data
*.npy
*.npz
# FIGURES AND TRACES ARE PATIENT DATA TOO. A dashboard PNG carries the subject
# ID and that infant's movement traces. It is derived from the video, so it
# inherits the video's governance. One slipped into this repo before this rule
# existed and had to be purged from history.
*.png
*.jpg
*.svg
*.pdf
series.json
dashboard.png
!docs/*.png

# Python
__pycache__/
*.pyc
.venv/
venv*/
.pytest_cache/

# scratch — build/debug logs and helper scripts. Not part of the tool.
_*.txt
_*.bat
_*.log
_*.py
!__init__.py

# Docs: publish only what the team needs
*.md
!README.md
!EVIDENCE.md
!PROTOCOL.md
!CHANGELOG.md
